# .streamlit/secrets.toml
# Copy this file to .streamlit/secrets.toml and fill in your values.
# This file is in .gitignore — never commit it.

# Optional: PostgreSQL connection string (leave empty to use local SQLite)
# DATABASE_URL = "postgresql://user:password@host:5432/dbname"

# Optional: Webhook auth token (set in TradingView alert URL as ?token=YOUR_TOKEN)
# WEBHOOK_TOKEN = "your_secret_token_here"
